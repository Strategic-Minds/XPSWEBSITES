{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/lead-followup",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; img-src * data:; font-src * data:;"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/get-quote",
      "destination": "/#contact",
      "permanent": false
    },
    {
      "source": "/estimate",
      "destination": "/#contact",
      "permanent": false
    },
    {
      "source": "/quote",
      "destination": "/#contact",
      "permanent": false
    }
  ]
}