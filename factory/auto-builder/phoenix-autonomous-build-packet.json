{
  "schema_version": "2026-06-16",
  "project": "Phoenix Epoxy Pros",
  "target_repo": "Strategic-Minds/XPSWEBSITES",
  "source_reference_repo": "Strategic-Minds/NASHVILLERESINWORX",
  "auto_builder_repo": "Strategic-Minds/AUTO_BUILDER",
  "drive_folder_url": "https://drive.google.com/drive/folders/1wdvro-T90CqXjcLtyACFXnlJ9vOqxuTk",
  "readiness_sheet_url": "https://docs.google.com/spreadsheets/d/1WbzhWAbXYBXXBlqn7GsgKcfkPvl0gHcbwSt3VyOHiK4",
  "scaffold_package_url": "https://drive.google.com/file/d/1hWYcvKMk4NRJiMfpOLZzRmtJ4w9hsz4F/view?usp=drivesdk",
  "mode": "sandbox_generation_with_placeholders",
  "apps": {
    "website": {
      "path": "apps/phoenix-epoxy-pros-site",
      "vercel_project_name": "phoenix-epoxy-pros",
      "pwa_required": true
    },
    "customer_job_app": {
      "path": "apps/phoenix-job-ops-app",
      "vercel_project_name": "phoenix-epoxy-pros-job-app",
      "pwa_required": true
    }
  },
  "cron": {
    "schedule": "*/5 * * * *",
    "endpoint": "/api/cron/factory-readiness",
    "purpose": "Validate build readiness, placeholder replacement state, deployment receipts, and owner approval progress every 5 minutes."
  },
  "validation_agents": [
    "branding-agent",
    "pwa-validation-agent",
    "seo-schema-agent",
    "forms-and-upload-agent",
    "backend-template-agent",
    "job-app-validation-agent"
  ],
  "generation_gates": [
    "repo_bootstrap_present",
    "scaffold_package_present",
    "drive_checklist_present",
    "placeholder_assets_present",
    "pwa_manifests_present",
    "lead_api_stub_present",
    "job_api_stub_present",
    "minimal_owner_inputs_recorded",
    "sandbox_preview_generated",
    "owner_review_requested"
  ],
  "do_not_block_sandbox_on": [
    "final_logo",
    "final_images",
    "live_payment_keys",
    "live_calendar_id",
    "live_crm_webhook",
    "live_sms_provider",
    "final_domain_dns"
  ],
  "block_production_on": [
    "owner_approval",
    "final_assets",
    "legal_disclaimers",
    "pricing_matrix",
    "payment_credentials",
    "calendar_credentials",
    "crm_email_sms_credentials",
    "domain_dns"
  ]
}
